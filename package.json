{
  "name": "smb-mounter",
  "version": "1.0.0",
  "description": "macOS SMB mount manager",
  "author": "SMB Mounter Team",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -b",
    "test": "tsc src/core/mountIdentity.ts src/core/systemMountMatcher.ts src/core/smb.ts src/renderer/ui/mountPresentation.ts --target ES2020 --module commonjs --rootDir src --outDir out-test --strict --skipLibCheck --jsx react-jsx && node --test test/mountIdentity.test.mjs test/iconAssets.test.mjs test/systemMountMatcher.test.mjs test/smb.test.mjs test/mountPresentation.test.mjs",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  },
  "build": {
    "appId": "com.smbmounter.app",
    "productName": "SMB Mounter",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
